+name: Release Build
+
+on:
+  workflow_dispatch:
+  push:
+    tags:
+      - "v*"
+
+jobs:
+  release-android-backend:
+    runs-on: ubuntu-latest
+    env:
+      NEOGENESIS_KEYSTORE_PATH: androidApp/keystore/release.jks
+      NEOGENESIS_KEYSTORE_PASSWORD: ${{ secrets.ANDROID_KEYSTORE_PASSWORD }}
+      NEOGENESIS_KEY_ALIAS: ${{ secrets.ANDROID_KEY_ALIAS }}
+      NEOGENESIS_KEY_PASSWORD: ${{ secrets.ANDROID_KEY_PASSWORD }}
+    steps:
+      - name: Checkout
+        uses: actions/checkout@v4
+
+      - name: Set up JDK
+        uses: actions/setup-java@v4
+        with:
+          distribution: "temurin"
+          java-version: "17"
+          cache: gradle
+
+      - name: Set up Android SDK
+        uses: android-actions/setup-android@v3
+
+      - name: Decode Android keystore
+        if: secrets.ANDROID_KEYSTORE_BASE64 != ''
+        run: |
+          mkdir -p androidApp/keystore
+          echo "${{ secrets.ANDROID_KEYSTORE_BASE64 }}" | base64 -d > androidApp/keystore/release.jks
+
+      - name: Build Android Release Artifacts
+        run: |
+          ./gradlew :androidApp:bundleRelease :androidApp:assembleRelease
+
+      - name: Build Backend Fat Jar
+        run: |
+          ./gradlew :backend:shadowJar
+
+      - name: Upload Android AAB
+        uses: actions/upload-artifact@v4
+        with:
+          name: android-aab
+          path: androidApp/build/outputs/bundle/release/*.aab
+
+      - name: Upload Android APK
+        uses: actions/upload-artifact@v4
+        with:
+          name: android-apk
+          path: androidApp/build/outputs/apk/release/*.apk
+
+      - name: Upload Backend Jar
+        uses: actions/upload-artifact@v4
+        with:
+          name: backend-jar
+          path: backend/build/libs/backend-all.jar
+
+      - name: Deploy to Google Play
+        if: secrets.PLAY_SERVICE_ACCOUNT_JSON != ''
+        uses: r0adkll/upload-google-play@v1
+        with:
+          serviceAccountJsonPlainText: ${{ secrets.PLAY_SERVICE_ACCOUNT_JSON }}
+          packageName: com.neogenesis.platform.android
+          releaseFiles: androidApp/build/outputs/bundle/release/*.aab
+          track: production
+          status: completed
+
+      - name: Deploy to Huawei AppGallery
+        if: secrets.HUAWEI_CLIENT_ID != ''
+        uses: muhamedzeema/appgallery-deply-action@main
+        with:
+          client-id: ${{ secrets.HUAWEI_CLIENT_ID }}
+          client-key: ${{ secrets.HUAWEI_CLIENT_KEY }}
+          app-id: ${{ secrets.HUAWEI_APP_ID }}
+          file-extension: "aab"
+          file-path: androidApp/build/outputs/bundle/release/androidApp-release.aab
+          file-name: "NeoGenesisPlatform-1.0.0"
+          submit: true
+
+      - name: Deploy to Amazon Appstore
+        if: secrets.AMAZON_APPSTORE_CLIENT_ID != ''
+        run: |
+          python -m pip install --upgrade pip
+          pip install requests
+          python tools/amazon_appstore_submit.py \
+            "${{ secrets.AMAZON_APPSTORE_CLIENT_ID }}" \
+            "${{ secrets.AMAZON_APPSTORE_CLIENT_SECRET }}" \
+            "${{ secrets.AMAZON_APPSTORE_APP_ID }}" \
+            "androidApp/build/outputs/apk/release/androidApp-release.apk"
+
+      - name: Install jq
+        run: |
+          sudo apt-get update
+          sudo apt-get install -y jq
+      - name: Deploy to Samsung Galaxy Store
+        if: secrets.SAMSUNG_ACCESS_TOKEN != ''
+        env:
+          SAMSUNG_ACCESS_TOKEN: ${{ secrets.SAMSUNG_ACCESS_TOKEN }}
+          SAMSUNG_SERVICE_ACCOUNT_ID: ${{ secrets.SAMSUNG_SERVICE_ACCOUNT_ID }}
+          SAMSUNG_CONTENT_ID: ${{ secrets.SAMSUNG_CONTENT_ID }}
+          SAMSUNG_GMS: ${{ secrets.SAMSUNG_GMS }}
+        run: |
+          set -e
+          APK_PATH="androidApp/build/outputs/apk/release/androidApp-release.apk"
+
+          SESSION_ID=$(curl -s -X POST "https://devapi.samsungapps.com/seller/createUploadSessionId" \
+            -H "Authorization: Bearer $SAMSUNG_ACCESS_TOKEN" \
+            -H "service-account-id: $SAMSUNG_SERVICE_ACCOUNT_ID" | jq -r '.sessionId')
+
+          FILEKEY=$(curl -s -X POST "https://seller.samsungapps.com/galaxyapi/fileUpload" \
+            -H "Authorization: Bearer $SAMSUNG_ACCESS_TOKEN" \
+            -H "service-account-id: $SAMSUNG_SERVICE_ACCOUNT_ID" \
+            -F "file=@${APK_PATH};type=application/vnd.android.package-archive;filename=NeoGenesisPlatform.apk" \
+            -F "sessionId=${SESSION_ID}" | jq -r '.fileKey')
+
+          CONTENT=$(curl -s -G "https://devapi.samsungapps.com/seller/contentInfo" \
+            -H "Authorization: Bearer $SAMSUNG_ACCESS_TOKEN" \
+            -H "service-account-id: $SAMSUNG_SERVICE_ACCOUNT_ID" \
+            --data-urlencode "contentId=${SAMSUNG_CONTENT_ID}")
+
+          DEFAULT_LANGUAGE=$(echo "$CONTENT" | jq -r '.defaultLanguageCode')
+          PAID=$(echo "$CONTENT" | jq -r '.paid')
+          PUBLICATION_TYPE=$(echo "$CONTENT" | jq -r '.publicationType')
+          APP_TITLE=$(echo "$CONTENT" | jq -r '.appTitle')
+          LONG_DESC=$(echo "$CONTENT" | jq -r '.longDescription')
+          SHORT_DESC=$(echo "$CONTENT" | jq -r '.shortDescription')
+          NEW_FEATURE=$(echo "$CONTENT" | jq -r '.newFeature')
+          SUPPORT_EMAIL=$(echo "$CONTENT" | jq -r '.supportEMail')
+          DEVICE_SEQ=$(echo "$CONTENT" | jq -r '.binaryList[0].binarySeq')
+
+          cat <<EOF > /tmp/content-update.json
+          {
+            "contentId": "${SAMSUNG_CONTENT_ID}",
+            "contentStatus": "REGISTERING",
+            "defaultLanguageCode": "${DEFAULT_LANGUAGE}",
+            "appTitle": "${APP_TITLE}",
+            "longDescription": "${LONG_DESC}",
+            "shortDescription": "${SHORT_DESC}",
+            "newFeature": "${NEW_FEATURE}",
+            "supportEMail": "${SUPPORT_EMAIL}",
+            "publicationType": "${PUBLICATION_TYPE}",
+            "paid": "${PAID}"
+          }
+          EOF
+
+          curl -s -X POST "https://devapi.samsungapps.com/seller/contentUpdate" \
+            -H "Content-Type: application/json" \
+            -H "Authorization: Bearer $SAMSUNG_ACCESS_TOKEN" \
+            -H "service-account-id: $SAMSUNG_SERVICE_ACCOUNT_ID" \
+            --data @/tmp/content-update.json | jq
+
+          curl -s -X POST "https://devapi.samsungapps.com/seller/v2/content/binary" \
+            -H "Content-Type: application/json" \
+            -H "Authorization: Bearer $SAMSUNG_ACCESS_TOKEN" \
+            -H "service-account-id: $SAMSUNG_SERVICE_ACCOUNT_ID" \
+            -d "{\"contentId\":\"${SAMSUNG_CONTENT_ID}\",\"gms\":\"${SAMSUNG_GMS:-Y}\",\"filekey\":\"${FILEKEY}\",\"binarySeqForDeviceInfo\":\"${DEVICE_SEQ}\"}" | jq
+
+          curl -s -X POST "https://devapi.samsungapps.com/seller/contentSubmit" \
+            -H "Content-Type: application/json" \
+            -H "Authorization: Bearer $SAMSUNG_ACCESS_TOKEN" \
+            -H "service-account-id: $SAMSUNG_SERVICE_ACCOUNT_ID" \
+            -d "{\"contentId\":\"${SAMSUNG_CONTENT_ID}\"}" | jq
+
+  desktop-packages:
+    runs-on: ${{ matrix.os }}
+    strategy:
+      matrix:
+        include:
+          - os: ubuntu-latest
+            gradle: "./gradlew"
+          - os: macos-latest
+            gradle: "./gradlew"
+          - os: windows-latest
+            gradle: ".\\gradlew.bat"
+    steps:
+      - name: Checkout
+        uses: actions/checkout@v4
+
+      - name: Set up JDK
+        uses: actions/setup-java@v4
+        with:
+          distribution: "temurin"
+          java-version: "17"
+          cache: gradle
+
+      - name: Install WiX (Windows)
+        if: runner.os == 'Windows'
+        run: choco install wixtoolset --yes
+        shell: pwsh
+
+      - name: Build Desktop Installer (Unix)
+        if: runner.os != 'Windows'
+        run: |
+          ./gradlew :desktopApp:packageReleaseDistributionForCurrentOS
+
+      - name: Build Desktop Installer (Windows)
+        if: runner.os == 'Windows'
+        run: |
+          .\\gradlew.bat :desktopApp:packageReleaseDistributionForCurrentOS
+        shell: pwsh
+      - name: Upload Desktop Artifacts
+        uses: actions/upload-artifact@v4
+        with:
+          name: desktop-${{ matrix.os }}
+          path: desktopApp/build/compose/binaries/main-release/**
+
+
+
