+syntax = "proto3";
+
+package neogenesis.firmware.v1;
+
+option java_multiple_files = true;
+option java_package = "com.neogenesis.platform.firmware.v1";
+
+message TelemetryFrame {
+  string job_id = 1;
+  string device_id = 2;
+  int64 timestamp_ms = 3;
+  double pressure_kpa = 4;
+  double displacement_um = 5;
+  double flow_rate_ul_s = 6;
+  double temperature_c = 7;
+  double viscosity_pas = 8;
+  double pid_p = 9;
+  double pid_i = 10;
+  double pid_d = 11;
+  int32 mpc_horizon_ms = 12;
+  double mpc_predicted_pressure_kpa = 13;
+}
+
+message DeviceHealth {
+  string device_id = 1;
+  int64 timestamp_ms = 2;
+  string status = 3;
+}
+
+message CommandRequest {
+  string command_id = 1;
+  string device_id = 2;
+  string command = 3;
+  string parameters_json = 4;
+}
+
+message CommandResponse {
+  string command_id = 1;
+  string device_id = 2;
+  bool accepted = 3;
+  string message = 4;
+}
+
+service FirmwareBridge {
+  rpc TelemetryStream(stream TelemetryFrame) returns (stream CommandRequest);
+  rpc HealthStream(stream DeviceHealth) returns (CommandResponse);
+}
