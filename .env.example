APP_ENV=dev
APP_VERSION=1.0.0
HTTP_PORT=8080
GRPC_PORT=9090
GRPC_ENABLED=true
DB_POOL_SIZE=10
DB_URL=jdbc:postgresql://postgres:5432/regenops
DB_USER=regenops
DB_PASSWORD=change_me
DB_DRIVER=org.postgresql.Driver
POSTGRES_DB=regenops
POSTGRES_USER=regenops
POSTGRES_PASSWORD=change_me
JWT_ISSUER=regenops-platform
JWT_AUDIENCE=regenops-users
JWT_SECRET=change_me
JWT_ACCESS_MS=3600000
JWT_REFRESH_MS=604800000
PAIRING_SECRET=change_me

# Control (KMP)
REGENOPS_HTTP_BASE_URL=http://localhost:8080
REGENOPS_GRPC_HOST=localhost
REGENOPS_GRPC_PORT=9090
REGENOPS_GRPC_TLS=false
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_AUDIENCE=
REGENOPS_TOKENSTORE_PASSWORD=

# Gateway
CORE_GRPC_HOST=localhost
CORE_GRPC_PORT=9090
CORE_GRPC_TLS=false
GATEWAY_ID=gateway-local
SIM_RUN_ID=run-simulated
